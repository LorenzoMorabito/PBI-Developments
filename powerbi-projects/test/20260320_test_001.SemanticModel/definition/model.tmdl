model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: it-IT
	dataAccessOptions
		fastCombine
		legacyRedirects
		returnErrorValuesAsNull

queryGroup STG

	annotation PBI_QueryGroupOrder = 0

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_QueryOrder = ["F_Sales","F_Promo","F_Finance","Country","Quarter","Month","Portfolio","Molecule","B_PortfolioMolecule","Sales Product","Promo Product","Finance Product","Sector","Diagnosis","Specialty","Channel","Feedback","root_path","MOD Flex Flat","_MOD Flex Flat Dimensions","_MOD Flex Flat Measures","_MOD Flex Pivot Inputs","_MOD Flex Pivot Selector","_MOD Flex Pivot Axis","MOD Flex Pivot","_MOD Finance Compare Inputs","_MOD Finance Compare Selector","MOD Finance Compare"]

annotation PBI_ProTooling = ["DaxQueryView_Desktop","DevMode"]

ref table Country
ref table Quarter
ref table Month
ref table Portfolio
ref table Molecule
ref table B_PortfolioMolecule
ref table 'Sales Product'
ref table 'Promo Product'
ref table 'Finance Product'
ref table F_Sales
ref table F_Promo
ref table F_Finance
ref table Sector
ref table Diagnosis
ref table Specialty
ref table Channel
ref table Feedback
ref table Sales
ref table Promo
ref table Finance
ref table 'MOD Flex Flat'
ref table '_MOD Flex Flat Dimensions'
ref table '_MOD Flex Flat Measures'
ref table '_MOD Flex Pivot Inputs'
ref table '_MOD Flex Pivot Selector'
ref table '_MOD Flex Pivot Axis'
ref table 'MOD Flex Pivot'
ref table '_MOD Finance Compare Inputs'
ref table '_MOD Finance Compare Selector'
ref table 'MOD Finance Compare'
ref cultureInfo en-US


table '_MOD Flex Flat Dimensions'
    isHidden

    column 'Flat Dimension'
        summarizeBy: none
        sourceColumn: [Value1]
        sortByColumn: 'Flat Dimension Order'

        relatedColumnDetails
            groupByColumn: 'Flat Dimension Fields'

    column 'Flat Dimension Fields'
        isHidden
        summarizeBy: none
        sourceColumn: [Value2]
        sortByColumn: 'Flat Dimension Order'

        extendedProperty ParameterMetadata =
                {
                  "version": 3,
                  "kind": 2
                }

    column 'Flat Dimension Order'
        isHidden
        formatString: 0
        summarizeBy: none
        sourceColumn: [Value3]

    partition '_MOD Flex Flat Dimensions' = calculated
        mode: import
        source =
                {
                ("Country", NAMEOF(Country[Country]), 0),
                ("Company", NAMEOF('Finance Product'[Company]), 1),
                ("Corporation Group", NAMEOF(Portfolio[Corporation Group]), 2)
                }
